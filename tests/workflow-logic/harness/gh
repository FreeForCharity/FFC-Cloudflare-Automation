#!/usr/bin/env bash
# Fake `gh` CLI for workflow-logic tests. Behavior is driven by TEST_* env
# vars set per scenario; every invocation is appended to $TEST_GH_LOG so
# tests can assert on which API calls were (or were not) made.
#
# Output strings simulate what the real `gh ... --jq` pipelines would print,
# so the workflow logic downstream of gh is exercised unchanged.

if [ -n "${TEST_GH_LOG:-}" ]; then
  printf '%s\n' "$*" >> "$TEST_GH_LOG"
fi

cmd="$1"
shift || true
args="$*"

case "$cmd" in
  api)
    case "$args" in
      *orgs/*/rulesets*)
        echo "${TEST_ORG_RULESETS:-1}"
        ;;
      *rules/branches/*)
        echo "${TEST_HAS_MQ:-0}"
        ;;
      *actions/workflows/*/runs*)
        # 736 preflight: list prior runs to find a matching successful dry-run.
        if [ "${TEST_RUNS_FAIL:-}" = "1" ]; then
          echo "simulated runs list failure" >&2
          exit 1
        fi
        # NOTE: the default is written with an if/else, not
        # ${TEST_WORKFLOW_RUNS:-{"workflow_runs":[]}} — bash's parser treats
        # literal unescaped braces inside a :- default word as nested-brace
        # markers, which corrupts the expansion in surprising ways once the
        # variable IS set (confirmed: it silently appends a stray `}` to the
        # real value, breaking every JSON payload here).
        if [ -n "${TEST_WORKFLOW_RUNS:-}" ]; then
          echo "$TEST_WORKFLOW_RUNS"
        else
          echo '{"workflow_runs":[]}'
        fi
        ;;
      orgs/*/repos\?* | orgs/*/repos\ * | orgs/*/repos)
        # Org repo LISTING for the preflight sibling scans (one name per line).
        # Deliberately does NOT match orgs/<org>/teams/<team>/repos/... — those
        # must keep routing to the */teams* branch below.
        if [ "${TEST_ORG_REPOS_FAIL:-}" = "1" ]; then
          echo "simulated org list failure" >&2
          exit 1
        fi
        printf '%s\n' "${TEST_ORG_REPOS:-}"
        ;;
      */teams*)
        if [ "${TEST_TEAMS_FAIL:-}" = "1" ]; then
          echo "simulated API failure" >&2
          exit 1
        fi
        # May be multi-line to simulate --paginate emitting one line per page.
        printf '%s\n' "${TEST_TEAMS_OUTPUT:-}"
        ;;
      "-X PATCH repos/"*)
        # 736 archive: PATCH repos/<owner>/<name> -F archived=true
        if [ "${TEST_PATCH_FAIL:-}" = "1" ]; then
          echo "simulated PATCH failure" >&2
          exit 1
        fi
        ;;
      *repos/*)
        # 736 archive GET: TEST_REPO_META is a JSON blob ("404" = not found).
        if [ -n "${TEST_REPO_META:-}" ]; then
          if [ "$TEST_REPO_META" = "404" ]; then
            echo "Not Found (HTTP 404)" >&2
            exit 1
          fi
          printf '%s\n' "$TEST_REPO_META"
        else
          # settings: squash|auto|del|upd (726 drift audit)
          echo "${TEST_REPO_SETTINGS:-false|true|true|true}"
        fi
        ;;
      *)
        exit 0
        ;;
    esac
    ;;
  repo)
    # gh repo list ... --jq → "name<TAB>visibility<TAB>defaultBranch" rows
    printf '%s\n' "${TEST_REPO_LIST:-}"
    ;;
  pr)
    # 502 deliver: gh pr list|view|create|merge chore/ga-data-sync --repo <r> ...
    sub="$1"
    case "$sub" in
      list)
        # `gh pr list --head <branch> --state open --json number --jq '.[].number'`:
        # prints the OPEN PR number(s) for the branch, one per line, or nothing.
        # TEST_OPEN_PR holds the open PR number (empty = no open PR). This is the
        # #737 guard — distinct from `pr view`, which also matches merged PRs.
        printf '%s\n' "${TEST_OPEN_PR:-}"
        ;;
      view)
        # A PR exists in ANY state (incl. merged) only when TEST_PR_EXISTS=1;
        # otherwise real gh exits non-zero. Retained so the #737 regression test
        # can prove `pr view` and `pr list --state open` diverge on a merged PR.
        [ "${TEST_PR_EXISTS:-}" = "1" ] && exit 0 || exit 1
        ;;
      create)
        if [ "${TEST_PR_CREATE_FAIL:-}" = "1" ]; then echo "simulated pr create failure" >&2; exit 1; fi
        ;;
      merge)
        # --merge --auto: real gh exits non-zero when auto-merge is unavailable;
        # the workflow tolerates that with `|| echo ...`.
        if [ "${TEST_PR_MERGE_FAIL:-}" = "1" ]; then echo "auto-merge unavailable" >&2; exit 1; fi
        ;;
    esac
    ;;
  issue)
    # 736 archive: gh issue comment|close|list <n|--repo r> ...
    case "$args" in
      comment*)
        if [ "${TEST_ISSUE_COMMENT_FAIL:-}" = "1" ]; then exit 1; fi
        ;;
      close*)
        if [ "${TEST_ISSUE_CLOSE_FAIL:-}" = "1" ]; then exit 1; fi
        ;;
      list*)
        # 736 preflight: search open issues referencing the target repo name.
        # Output is pre-formatted, as if --jq already ran (see file header).
        if [ "${TEST_ISSUE_LIST_FAIL:-}" = "1" ]; then
          echo "simulated issue list failure" >&2
          exit 1
        fi
        printf '%s\n' "${TEST_OPEN_ISSUES:-}"
        ;;
    esac
    ;;
  *)
    exit 0
    ;;
esac
