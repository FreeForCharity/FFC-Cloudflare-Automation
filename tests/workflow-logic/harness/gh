#!/usr/bin/env bash
# Fake `gh` CLI for workflow-logic tests. Behavior is driven by TEST_* env
# vars set per scenario; every invocation is appended to $TEST_GH_LOG so
# tests can assert on which API calls were (or were not) made.
#
# Output strings simulate what the real `gh ... --jq` pipelines would print,
# so the workflow logic downstream of gh is exercised unchanged.

if [ -n "${TEST_GH_LOG:-}" ]; then
  printf '%s\n' "$*" >> "$TEST_GH_LOG"
fi

cmd="$1"
shift || true
args="$*"

case "$cmd" in
  api)
    case "$args" in
      *orgs/*/rulesets*)
        echo "${TEST_ORG_RULESETS:-1}"
        ;;
      *rules/branches/*)
        echo "${TEST_HAS_MQ:-0}"
        ;;
      orgs/*/repos\?* | orgs/*/repos\ * | orgs/*/repos)
        # Org repo LISTING for the preflight sibling scans (one name per line).
        # Deliberately does NOT match orgs/<org>/teams/<team>/repos/... — those
        # must keep routing to the */teams* branch below.
        if [ "${TEST_ORG_REPOS_FAIL:-}" = "1" ]; then
          echo "simulated org list failure" >&2
          exit 1
        fi
        printf '%s\n' "${TEST_ORG_REPOS:-}"
        ;;
      */teams*)
        if [ "${TEST_TEAMS_FAIL:-}" = "1" ]; then
          echo "simulated API failure" >&2
          exit 1
        fi
        # May be multi-line to simulate --paginate emitting one line per page.
        printf '%s\n' "${TEST_TEAMS_OUTPUT:-}"
        ;;
      "-X PATCH repos/"*)
        # 736 archive: PATCH repos/<owner>/<name> -F archived=true
        if [ "${TEST_PATCH_FAIL:-}" = "1" ]; then
          echo "simulated PATCH failure" >&2
          exit 1
        fi
        ;;
      *repos/*)
        # 736 archive GET: TEST_REPO_META is a JSON blob ("404" = not found).
        if [ -n "${TEST_REPO_META:-}" ]; then
          if [ "$TEST_REPO_META" = "404" ]; then
            echo "Not Found (HTTP 404)" >&2
            exit 1
          fi
          printf '%s\n' "$TEST_REPO_META"
        else
          # settings: squash|auto|del|upd (726 drift audit)
          echo "${TEST_REPO_SETTINGS:-false|true|true|true}"
        fi
        ;;
      *)
        exit 0
        ;;
    esac
    ;;
  repo)
    # gh repo list ... --jq → "name<TAB>visibility<TAB>defaultBranch" rows
    printf '%s\n' "${TEST_REPO_LIST:-}"
    ;;
  issue)
    # 736 archive: gh issue comment|close <n> --repo <r> ...
    case "$args" in
      comment*)
        if [ "${TEST_ISSUE_COMMENT_FAIL:-}" = "1" ]; then exit 1; fi
        ;;
      close*)
        if [ "${TEST_ISSUE_CLOSE_FAIL:-}" = "1" ]; then exit 1; fi
        ;;
    esac
    ;;
  *)
    exit 0
    ;;
esac
